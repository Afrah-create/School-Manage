# Copy to apps/api/.env or use the monorepo root .env (scripts load both).

# Database & auth (see root .env.example for full list)
DATABASE_URL=postgresql://user:password@localhost:5432/school_manage
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Outbound email (Resend) — optional in local dev; required in production for auth emails
RESEND_API_KEY=
# Must use an address on a domain verified in the SAME Resend account as RESEND_API_KEY.
# If only a subdomain is verified (e.g. schoolmanage.slimcybertech.com), use that host here:
EMAIL_FROM=SchoolManage <noreply@schoolmanage.slimcybertech.com>
# Optional: force a verified sending domain when EMAIL_FROM still uses the apex domain
# RESEND_FROM_DOMAIN=schoolmanage.slimcybertech.com

# Web app URL for links inside emails (password reset, etc.)
WEB_APP_URL=http://localhost:3000
